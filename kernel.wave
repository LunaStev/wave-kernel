import("state");
import("hal");
import("term");
import("input");
import("shell");
import("keyboard");

fun k_on_timer_tick() {
    TIMER_TICKS += 1;
}

fun k_main() {
    asm_disable_interrupts();

    term_clear();
    cursor_init_hw();
    input_clear();

    term_write("WaveOS Example Kernel\n");
    term_write("Booted in long mode.\n");
    term_write("Type 'help' for commands.\n\n");
    show_prompt();

    asm_enable_interrupts();

    while (true) {
        asm_halt();
    }
}
